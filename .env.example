# Required for JWT authentication (generate with: node generate-secrets.js)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here
REFRESH_SECRET=your-refresh-secret-key-min-32-chars-here

# Admin credentials
ADMIN_USERNAME=portfolioadmin
ADMIN_PASSWORD=Admin123

# Let's Encrypt configuration (optional)
DOMAIN=yourdomain.com
EMAIL=you@yourdomain.com
STAGING=true  # Set to false for production certificates